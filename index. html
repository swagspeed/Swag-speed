<!DOCTYPE html>
<html>
<head>
    <title>Swag-speed Business</title>
    <style>
        body { font-family: Arial; padding: 20px; }
        input { display: block; margin: 10px 0; padding: 8px; width: 80%; }
        button { padding: 10px 20px; background: green; color: white; border: none; cursor: pointer; }
    </style>
</head>
<body>
    <h1>Swag-speed Management</h1>
    <input type="text" id="custName" placeholder="Customer Name">
    <input type="text" id="item" placeholder="Product Name">
    <button onclick="saveOrder()">Save Order</button>

    <script>
        function saveOrder() {
            let name = document.getElementById('custName').value;
            let item = document.getElementById('item').value;
            if(name && item) {
                alert("Swag-speed order saved for: " + name);
            } else {
                alert("Please fill all details!");
            }
        }
    </script>
</body>
</html>
